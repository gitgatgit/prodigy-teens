{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 04 — Geographic Visualization\n",
    "\n",
    "Interactive maps showing prodigy probability estimates across Mexico and zoomed into the Danish Embassy query.\n",
    "\n",
    "**Outputs:**\n",
    "- Choropleth map of P(≥1 prodigy) by municipality\n",
    "- Radius query map centered on Danish Embassy, CDMX\n",
    "- Heatmap of university density in CDMX"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "import folium\n",
    "from folium.plugins import HeatMap\n",
    "import plotly.express as px\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "from src.model import ProdigyProbabilityModel, ModelConfig\n",
    "from src.geo_utils import (\n",
    "    geodesic_buffer,\n",
    "    build_radius_map,\n",
    "    build_choropleth_map,\n",
    "    save_map,\n",
    "    DANISH_EMBASSY_CDMX,\n",
    ")\n",
    "\n",
    "model = ProdigyProbabilityModel(ModelConfig(n_samples=20_000))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Radius Query Map — Danish Embassy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "emb = DANISH_EMBASSY_CDMX\n",
    "\n",
    "# Estimate for Miguel Hidalgo (contains Polanco)\n",
    "mh = model.estimate_municipality(\n",
    "    'Miguel Hidalgo, CDMX', 364_439, 46.99,\n",
    "    is_urban=True, is_high_edu_state=True, marginalization_index=0.04\n",
    ")\n",
    "radius_1km = model.estimate_radius(mh, radius_km=1.0)\n",
    "\n",
    "# Build map\n",
    "m = build_radius_map(\n",
    "    center_lat=emb['lat'],\n",
    "    center_lon=emb['lon'],\n",
    "    radius_km=1.0,\n",
    "    prob_at_least_one=radius_1km.prob_at_least_one,\n",
    "    expected_count=radius_1km.expected_count,\n",
    "    label=emb['name'],\n",
    ")\n",
    "\n",
    "# Add Polanco neighborhood context\n",
    "folium.Marker(\n",
    "    location=[19.4326, -99.1332],\n",
    "    popup='Zócalo, CDMX',\n",
    "    icon=folium.Icon(color='blue', icon='info-sign')\n",
    ").add_to(m)\n",
    "\n",
    "save_map(m, 'danish_embassy_radius.html')\n",
    "m"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Multi-Radius Comparison Map"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "m2 = folium.Map(\n",
    "    location=[emb['lat'], emb['lon']],\n",
    "    zoom_start=13,\n",
    "    tiles='CartoDB positron'\n",
    ")\n",
    "\n",
    "colors = ['#2a9d8f', '#e9c46a', '#f4a261', '#e76f51', '#e63946']\n",
    "radii = [0.5, 1.0, 2.0, 5.0, 10.0]\n",
    "\n",
    "for r, color in zip(radii, colors):\n",
    "    est = model.estimate_radius(mh, radius_km=r)\n",
    "    folium.Circle(\n",
    "        location=[emb['lat'], emb['lon']],\n",
    "        radius=r * 1000,\n",
    "        color=color,\n",
    "        fill=True,\n",
    "        fill_opacity=0.08,\n",
    "        weight=2,\n",
    "        popup=folium.Popup(\n",
    "            f\"<b>Radius: {r:.1f} km</b><br>\"\n",
    "            f\"P(≥1 prodigy): {est.prob_at_least_one:.3e}<br>\"\n",
    "            f\"Expected count: {est.expected_count:.6f}<br>\"\n",
    "            f\"Est. population: {est.population:,}\",\n",
    "            max_width=220,\n",
    "        ),\n",
    "    ).add_to(m2)\n",
    "\n",
    "folium.Marker(\n",
    "    location=[emb['lat'], emb['lon']],\n",
    "    popup='🇩🇰 Danish Embassy',\n",
    "    icon=folium.Icon(color='red', icon='flag'),\n",
    ").add_to(m2)\n",
    "\n",
    "save_map(m2, 'multi_radius_danish_embassy.html')\n",
    "m2"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Plotly: Mexico Map with Probability Bubbles\n",
    "\n",
    "Since we don't have all municipality shapefiles loaded in this demo, we use city-level estimates as bubble markers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "cities = [\n",
    "    {'city': 'CDMX', 'lat': 19.4326, 'lon': -99.1332, 'population': 9_209_944, 'area_km2': 1_495, 'is_high_edu': True, 'marginalization': 0.05},\n",
    "    {'city': 'Monterrey', 'lat': 25.6866, 'lon': -100.3161, 'population': 1_135_512, 'area_km2': 325, 'is_high_edu': True, 'marginalization': 0.08},\n",
    "    {'city': 'Guadalajara', 'lat': 20.6597, 'lon': -103.3496, 'population': 1_385_629, 'area_km2': 151, 'is_high_edu': True, 'marginalization': 0.10},\n",
    "    {'city': 'Puebla', 'lat': 19.0414, 'lon': -98.2063, 'population': 1_692_181, 'area_km2': 534, 'is_high_edu': False, 'marginalization': 0.20},\n",
    "    {'city': 'Tijuana', 'lat': 32.5149, 'lon': -117.0382, 'population': 1_810_645, 'area_km2': 634, 'is_high_edu': False, 'marginalization': 0.15},\n",
    "    {'city': 'León', 'lat': 21.1236, 'lon': -101.6860, 'population': 1_578_626, 'area_km2': 1_219, 'is_high_edu': False, 'marginalization': 0.18},\n",
    "    {'city': 'Mérida', 'lat': 20.9674, 'lon': -89.6234, 'population': 892_363, 'area_km2': 858, 'is_high_edu': False, 'marginalization': 0.15},\n",
    "    {'city': 'Querétaro', 'lat': 20.5888, 'lon': -100.3899, 'population': 878_931, 'area_km2': 759, 'is_high_edu': True, 'marginalization': 0.12},\n",
    "    {'city': 'San Luis Potosí', 'lat': 22.1565, 'lon': -100.9855, 'population': 824_229, 'area_km2': 1_443, 'is_high_edu': False, 'marginalization': 0.22},\n",
    "    {'city': 'Oaxaca', 'lat': 17.0732, 'lon': -96.7266, 'population': 264_217, 'area_km2': 88, 'is_high_edu': False, 'marginalization': 0.38},\n",
    "]\n",
    "\n",
    "city_results = []\n",
    "for c in cities:\n",
    "    est = model.estimate_municipality(\n",
    "        c['city'], c['population'], c['area_km2'],\n",
    "        is_urban=True,\n",
    "        is_high_edu_state=c['is_high_edu'],\n",
    "        marginalization_index=c['marginalization'],\n",
    "    )\n",
    "    city_results.append({\n",
    "        'city': c['city'],\n",
    "        'lat': c['lat'],\n",
    "        'lon': c['lon'],\n",
    "        'prob': est.prob_at_least_one,\n",
    "        'expected': est.expected_count,\n",
    "        'population': c['population'],\n",
    "    })\n",
    "\n",
    "city_df = pd.DataFrame(city_results)\n",
    "\n",
    "fig = px.scatter_mapbox(\n",
    "    city_df,\n",
    "    lat='lat', lon='lon',\n",
    "    size='prob',\n",
    "    color='prob',\n",
    "    hover_name='city',\n",
    "    hover_data={'prob': ':.3e', 'expected': ':.5f', 'population': ':,', 'lat': False, 'lon': False},\n",
    "    color_continuous_scale='YlOrRd',\n",
    "    size_max=40,\n",
    "    zoom=4.5,\n",
    "    center={'lat': 23.6, 'lon': -102.5},\n",
    "    mapbox_style='carto-positron',\n",
    "    title='P(≥1 Sub-18 Graduate) by Mexican City',\n",
    "    labels={'prob': 'P(≥1 prodigy)'},\n",
    ")\n",
    "fig.update_layout(height=600)\n",
    "fig.show()\n",
    "fig.write_html('../outputs/maps/mexico_city_probabilities.html')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Final Summary Table"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\\n=== FINAL SUMMARY: Danish Embassy Query ===\")\n",
    "print(f\"  Location: {emb['name']}\")\n",
    "print(f\"  Coordinates: {emb['lat']}°N, {emb['lon']}°W\")\n",
    "print(f\"  Municipality: Miguel Hidalgo, CDMX\")\n",
    "print(f\"  Radius: 1.0 km\")\n",
    "print(f\"  Area of circle: {np.pi:.3f} km²\")\n",
    "print(f\"  Est. population in radius: {radius_1km.population:,}\")\n",
    "print(f\"  Expected count: {radius_1km.expected_count:.8f}\")\n",
    "print(f\"  P(≥1 prodigy): {radius_1km.prob_at_least_one:.8f}\")\n",
    "print(f\"  ≈ 1 in {1/radius_1km.prob_at_least_one:,.0f} chance per year\")"
   ]
  }
 ],
